{
  "bsonType": "object",
  "required": ["user_id", "type", "content", "status"],
  "properties": {
    "_id": { "description": "ID" },
    "user_id": { "bsonType": "string" },
    "type": { "bsonType": "string", "enum": ["投诉", "建议"] },
    "content": { "bsonType": "string" },
    "images": { "bsonType": "array" },
    "contact_type": { "bsonType": "string" },
    "contact_value": { "bsonType": "string" },
    "rel_order_no": { "bsonType": "string", "description": "关联报修工单号（选填）" },
    "status": {
      "bsonType": "string",
      "description": "处理状态",
      "enum": ["待处理", "处理中", "已回复", "已结案", "已升级", "已处理"]
    },
    "urgency": {
      "bsonType": "string",
      "description": "紧急等级：高危=诊所停业",
      "enum": ["普通", "重要", "高危"]
    },
    "handler_id": { "bsonType": "string", "description": "处理负责人 user_id" },
    "handler_name": { "bsonType": "string", "description": "处理负责人姓名（冗余）" },
    "reply": { "bsonType": "string", "description": "对客户的官方回复（小程序端可见）" },
    "process_result": {
      "bsonType": "string",
      "description": "问题核实结果：设备质量/人为损坏/物流问题等"
    },
    "process_note": { "bsonType": "string", "description": "内部备注（仅后台可见）" },
    "visit_time": { "bsonType": "timestamp", "description": "回访时间" },
    "visit_by": { "bsonType": "string", "description": "回访人姓名" },
    "visit_satisfaction": {
      "bsonType": "string",
      "description": "客户满意度",
      "enum": ["满意", "一般", "不满意"]
    },
    "visit_opinion": { "bsonType": "string", "description": "客户最终意见" },
    "upgrade_note": { "bsonType": "string", "description": "升级投诉说明" },
    "handled_time": { "bsonType": "timestamp", "description": "首次处理/回复时间" },
    "update_time": { "bsonType": "timestamp" },
    "create_time": { "bsonType": "timestamp" }
  }
}
