# 后台接口基础地址
# 复制为 .env.local 后按联调环境修改；不配置时默认使用 utils/request.js 里的线上地址。
VITE_API_BASE_URL=https://api.cisco-d.com/api/v1

# 微信支付配置写在 uniCloud 云函数环境变量中，不要写入前端 .env.local。
# cicada-client-order 需要配置：
# WX_APPID=wx25289fbe4a3bf011
# WX_SECRET=请在 uniCloud 环境变量中配置，不要提交到仓库
# WX_PAY_APPID=wx25289fbe4a3bf011
# WX_PAY_MCH_ID=商户号
# WX_PAY_SERIAL_NO=商户 API 证书序列号
# WX_PAY_NOTIFY_URL=https://你的云函数URL化地址/cicada-client-order/wechatPayNotify
# WX_PAY_PRIVATE_KEY_BASE64=商户 API 私钥 base64 后的内容
# WX_PAY_API_V3_KEY=微信支付 APIv3 密钥，32字节
